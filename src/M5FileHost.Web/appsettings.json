{
  "AllowedHosts": "files.index.sarl;localhost;127.0.0.1",
  "Uploads": {
    "RootPath": "./data/uploads",
    "MaxFileSizeMb": 512,
    "MaxFilesPerUpload": 20,
    "KeepOriginalFiles": true,
    "BlockedExtensions": [ ".exe", ".dll", ".com", ".scr", ".msi", ".bat", ".cmd", ".ps1", ".sh", ".apk", ".jar" ]
  },
  "ClamAv": { "Enabled": false, "Host": "clamav", "Port": 3310, "TimeoutSeconds": 120 },
  "Features": { "EnableRegistration": true, "EnablePublicUploadsPage": true, "EnableNsfw": true },
  "Database": { "MigrateOnStartup": false },
  "DataProtection": { "KeysPath": "./data/keys" },
  "Email": { "Host": "", "Port": 587, "Username": "", "Password": "", "FromAddress": "", "EnableSsl": true },
  "Logging": { "LogLevel": { "Default": "Information", "Microsoft.AspNetCore": "Warning", "Microsoft.EntityFrameworkCore.Database.Command": "Warning" } }
}
