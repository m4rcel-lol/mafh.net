<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Program).Assembly">
        <Found Context="routeData"><AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)"><NotAuthorized><div class="center-state"><div class="state-icon">🔐</div><h1>Sign in required</h1><p>This space belongs to your account.</p><a class="button filled" href="/login">Sign in</a></div></NotAuthorized></AuthorizeRouteView><FocusOnNavigate RouteData="routeData" Selector="h1" /></Found>
        <NotFound><LayoutView Layout="typeof(Layout.MainLayout)"><div class="center-state"><div class="state-icon">🪐</div><h1>Lost in storage</h1><p>That page does not exist.</p><a class="button tonal" href="/">Back home</a></div></LayoutView></NotFound>
    </Router>
</CascadingAuthenticationState>
