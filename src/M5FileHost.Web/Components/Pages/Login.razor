@page "/login"
@inject NavigationManager Navigation
<PageTitle>Sign in · m5 file hoster</PageTitle>
<div class="auth-page">
    <section class="auth-card reveal">
        <a class="brand solo" href="/"><span class="brand-mark">m5</span></a>
        <span class="eyebrow">WELCOME BACK</span>
        <h1>Sign in to your space</h1>
        <p class="subtle">Your uploads missed you.</p>
        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <div class="notice error">@Error</div>
        }
        <form method="post" action="/api/auth/login" class="form-stack">
            <AntiforgeryToken />
            <label><span>Email or username</span><input name="Login" required maxlength="254" autocomplete="username" autofocus /></label>
            <label><span>Password</span><input type="password" name="Password" required maxlength="128" autocomplete="current-password" /></label>
            <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />
            <label class="check"><input type="checkbox" name="RememberMe" value="true" /><span>Keep me signed in</span></label>
            <button class="button filled full" type="submit">Sign in →</button>
        </form>
        <div class="auth-links"><a href="/forgot-password">Forgot password?</a><span>New here? <a href="/register">Create an account</a></span></div>
    </section>
</div>
@code {
    private string? Error => GetQuery("error");
    private string? ReturnUrl => GetQuery("returnUrl");
    private string? GetQuery(string name) { var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(new Uri(Navigation.Uri).Query); return query.TryGetValue(name, out var value) ? value.ToString() : null; }
}
