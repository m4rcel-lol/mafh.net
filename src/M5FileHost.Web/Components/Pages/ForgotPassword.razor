@page "/forgot-password"
@inject NavigationManager Navigation
<PageTitle>Reset password · m5 file hoster</PageTitle>
<div class="auth-page">
    <section class="auth-card">
        <span class="state-icon">✉</span><h1>Reset your password</h1>
        @if (Sent)
        {
            <div class="notice success">If that account exists, reset instructions have been requested. Email delivery must be configured by the server owner.</div>
        }
        else
        {
            <p class="subtle">Enter your account email. The response is intentionally the same for every address.</p>
            <form method="post" action="/api/auth/forgot-password" class="form-stack">
                <AntiforgeryToken /><label><span>Email</span><input type="email" name="email" required autocomplete="email" /></label>
                <button class="button filled full">Request reset</button>
            </form>
        }
        <div class="auth-links center"><a href="/login">← Back to sign in</a></div>
    </section>
</div>
@code { private bool Sent => new Uri(Navigation.Uri).Query.Contains("sent=1", StringComparison.Ordinal); }
