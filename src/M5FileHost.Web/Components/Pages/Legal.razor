@page "/terms"
@page "/privacy"
@page "/rules"
@page "/dmca"
@inject NavigationManager Navigation
<PageTitle>@Title · m5 file hoster</PageTitle>
<article class="legal surface">
    <span class="eyebrow">CLEAR, HUMAN RULES</span><h1>@Title</h1>
    <p class="lead">Last updated June 27, 2026. This template must be reviewed for the laws applicable to the operator before public launch.</p>
    <h2>Content and acceptable use</h2>
    <p>Do not upload illegal content, malware, stolen data, doxxing, child sexual abuse material or sexual content involving minors, non-consensual intimate content, credible threats, targeted abuse, or material that infringes copyright.</p>
    <h2>Privacy and operations</h2>
    <p>The service stores account identifiers, profile fields, files, upload metadata, security events and operational logs required to provide and secure the service. Configure retention and deletion periods for the operator's jurisdiction.</p>
    <h2>Adult content</h2>
    <p>Legal adult content may only be hosted where lawful and must be marked NSFW. It is hidden and blurred by default. The operator may remove any content at their discretion.</p>
    <h2>Copyright notices</h2>
    <p>A notice should identify the copyrighted work, exact file URL, claimant contact details, good-faith statement, accuracy statement and signature. Configure the operator's legal name, address and designated email before launch.</p>
    <h2>Availability and enforcement</h2>
    <p>Maintain independent backups. Content may be hidden during review; accounts may be suspended; serious illegal activity may be reported to the appropriate authorities.</p>
</article>
@code { private string Path => new Uri(Navigation.Uri).AbsolutePath; private string Title => Path switch { "/privacy" => "Privacy policy", "/rules" => "Content rules", "/dmca" => "Copyright & DMCA", _ => "Terms of service" }; }
