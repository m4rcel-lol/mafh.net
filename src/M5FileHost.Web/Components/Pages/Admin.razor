@page "/admin"
@page "/admin/{Section}"
@attribute [Authorize(Policy = "Moderator")]
@inject AppDbContext Database
<PageTitle>Admin · m5 file hoster</PageTitle>
<form hidden><AntiforgeryToken /></form>
<div class="admin-shell">
    <aside class="admin-nav">
        <span class="eyebrow">CONTROL ROOM</span><h2>Admin</h2>
        <NavLink href="/admin" Match="NavLinkMatch.All">Overview</NavLink><NavLink href="/admin/files">Files</NavLink><NavLink href="/admin/users">Users</NavLink><NavLink href="/admin/reports">Reports <span class="nav-count">@_reports.Count</span></NavLink><NavLink href="/admin/storage">Storage</NavLink><NavLink href="/admin/jobs">Jobs</NavLink><NavLink href="/admin/audit-log">Audit log</NavLink><NavLink href="/admin/settings">Settings</NavLink>
    </aside>
    <div class="admin-content">
        @if (string.IsNullOrWhiteSpace(Section))
        {
            <AdminHeading Title="Everything at a glance" Subtitle="Users, storage, safety and processing health." />
            <div class="stat-grid">
                <article class="stat-card purple"><span>USERS</span><strong>@_totalUsers</strong><small>@_bannedCount banned</small></article>
                <article class="stat-card green"><span>FILES</span><strong>@_totalFiles</strong><small>@_todayCount today</small></article>
                <article class="stat-card orange"><span>STORAGE</span><strong>@Format(TotalOriginal)</strong><small>@SavingsPercent% saved</small></article>
                <article class="stat-card blue"><span>REPORTS</span><strong>@_reports.Count</strong><small>need attention</small></article>
            </div>
            <section class="surface">
                <h2>Recent uploads</h2>
                <div class="data-list">
                    @foreach (var file in _files.Take(8))
                    {
                        <a href="/f/@file.Slug"><strong>@file.OriginalName</strong><span>&#64;@file.Uploader.UserName</span><span>@Format(file.OriginalSize)</span><span class="status @file.ProcessingStatus.ToString().ToLowerInvariant()">@file.ProcessingStatus</span></a>
                    }
                </div>
            </section>
        }
        else if (Section == "files")
        {
            <AdminHeading Title="File management" Subtitle="Inspect paths, hide, classify or remove uploads." />
            <div class="surface table-wrap"><table><thead><tr><th>File</th><th>Uploader</th><th>Size</th><th>State</th><th>Actions</th></tr></thead><tbody>
                @foreach (var file in _files)
                {
                    <tr><td><a href="/f/@file.Slug"><strong>@file.OriginalName</strong></a><small>@file.OriginalPath</small></td><td>&#64;@file.Uploader.UserName</td><td>@Format(file.OriginalSize)</td><td>@FileState(file)</td><td><button class="icon-button" data-admin-toggle="/api/admin/files/@file.Id" data-field="IsHidden" data-value="@(!file.IsHidden)">@(file.IsHidden ? "Show" : "Hide")</button><button class="icon-button" data-admin-toggle="/api/admin/files/@file.Id" data-field="IsNsfw" data-value="@(!file.IsNsfw)">18+</button><button class="icon-button danger-text" data-api-delete="/api/admin/files/@file.Id">Delete</button></td></tr>
                }
            </tbody></table></div>
        }
        else if (Section == "users")
        {
            <AdminHeading Title="People" Subtitle="Roles, status, quotas and account moderation." />
            <div class="surface table-wrap"><table><thead><tr><th>User</th><th>Role</th><th>Uploads</th><th>Storage</th><th>Status</th><th>Actions</th></tr></thead><tbody>
                @foreach (var user in _users)
                {
                    <tr><td><a href="/u/@user.UserName"><strong>&#64;@user.UserName</strong></a><small>@user.Email</small></td><td><select class="user-role"><option selected="@(user.Role == UserRole.User)">User</option><option selected="@(user.Role == UserRole.Moderator)">Moderator</option><option selected="@(user.Role == UserRole.Admin)">Admin</option><option selected="@(user.Role == UserRole.Owner)">Owner</option></select></td><td>@user.Files.Count</td><td>@Format(user.Files.Sum(x => x.OriginalSize))</td><td>@(user.IsBanned ? "Banned" : "Active")</td><td><button class="icon-button" data-admin-role="/api/admin/users/@user.Id">Save role</button><button class="icon-button" data-admin-user-toggle="/api/admin/users/@user.Id" data-value="@(!user.IsBanned)">@(user.IsBanned ? "Unban" : "Ban")</button><button class="icon-button danger-text" data-api-delete="/api/admin/users/@user.Id?deleteFiles=true">Delete</button></td></tr>
                }
            </tbody></table></div>
        }
        else if (Section == "reports")
        {
            <AdminHeading Title="Reports" Subtitle="Review community safety signals with context." />
            <div class="report-grid">
                @foreach (var report in _reports)
                {
                    <article class="surface report-card"><div><span class="chip danger">@report.Reason</span><small>@report.CreatedAt.ToString("g")</small></div><h3><a href="/f/@report.File.Slug">@report.File.OriginalName</a></h3><p>@report.Message</p><div><button class="button tonal compact" data-admin-report="/api/admin/reports/@report.Id" data-status="Ignored">Ignore</button><button class="button filled compact" data-admin-report="/api/admin/reports/@report.Id" data-status="Resolved">Resolve</button></div></article>
                }
            </div>
        }
        else if (Section == "storage")
        {
            <AdminHeading Title="Storage" Subtitle="Physical local-file usage and optimization impact." />
            <div class="stat-grid"><article class="stat-card purple"><span>ORIGINALS</span><strong>@Format(TotalOriginal)</strong></article><article class="stat-card green"><span>PROCESSED</span><strong>@Format(TotalProcessed)</strong></article><article class="stat-card orange"><span>SAVED</span><strong>@SavingsPercent%</strong></article><article class="stat-card blue"><span>FILES</span><strong>@_totalFiles</strong></article></div>
            <section class="surface"><h2>Usage by file type</h2>
                @foreach (var group in _files.GroupBy(x => x.Type).OrderByDescending(x => x.Sum(f => f.OriginalSize)))
                {
                    <div class="usage-row"><span>@group.Key</span><div class="meter"><i style="@TypeStyle(group.Sum(x => x.OriginalSize))"></i></div><strong>@Format(group.Sum(x => x.OriginalSize))</strong></div>
                }
            </section>
        }
        else if (Section == "jobs")
        {
            <AdminHeading Title="Processing jobs" Subtitle="Durable Redis queue with database-backed recovery." />
            <div class="stat-grid"><article class="stat-card purple"><span>PENDING</span><strong>@PendingCount</strong></article><article class="stat-card blue"><span>RUNNING</span><strong>@RunningCount</strong></article><article class="stat-card green"><span>COMPLETE</span><strong>@CompleteCount</strong></article><article class="stat-card orange"><span>FAILED</span><strong>@FailedCount</strong></article></div>
        }
        else if (Section == "audit-log")
        {
            <AdminHeading Title="Audit log" Subtitle="An immutable view of privileged actions." />
            <div class="surface table-wrap"><table><thead><tr><th>Time</th><th>Actor</th><th>Action</th><th>Target</th><th>IP</th></tr></thead><tbody>
                @foreach (var log in _audit)
                {
                    <tr><td>@log.CreatedAt.ToString("g")</td><td>@(log.Actor?.UserName ?? "system")</td><td><code>@log.Action</code></td><td>@log.TargetType · @log.TargetId</td><td>@log.IpAddress</td></tr>
                }
            </tbody></table></div>
        }
        else
        {
            <AdminHeading Title="Server settings" Subtitle="Security-sensitive settings are controlled through environment variables." />
            <section class="surface settings-card"><h2>Runtime configuration</h2><p>Registration, upload limits, ClamAV and owner credentials are configured in <code>.env</code>, not through a public request surface.</p><p>Apply changes with <code>docker compose up -d</code>.</p></section>
        }
    </div>
</div>
@code {
    [Parameter] public string? Section { get; set; }
    private List<FileUpload> _files = []; private List<ApplicationUser> _users = []; private List<Report> _reports = []; private List<AuditLog> _audit = [];
    private int _totalUsers; private int _totalFiles; private int _bannedCount; private int _todayCount; private long _totalOriginal; private long _totalProcessed;
    private long TotalOriginal => _totalOriginal; private long TotalProcessed => _totalProcessed;
    private int SavingsPercent => TotalOriginal == 0 ? 0 : Math.Max(0, (int)Math.Round(100d * (TotalOriginal - TotalProcessed) / TotalOriginal));
    private int PendingCount => _files.Count(x => x.ProcessingStatus == ProcessingStatus.Pending); private int RunningCount => _files.Count(x => x.ProcessingStatus == ProcessingStatus.Processing); private int CompleteCount => _files.Count(x => x.ProcessingStatus == ProcessingStatus.Complete); private int FailedCount => _files.Count(x => x.ProcessingStatus == ProcessingStatus.Failed);
    protected override async Task OnInitializedAsync() { _totalUsers = await Database.Users.CountAsync(); _totalFiles = await Database.Files.CountAsync(); _bannedCount = await Database.Users.CountAsync(x => x.IsBanned); _todayCount = await Database.Files.CountAsync(x => x.CreatedAt > DateTimeOffset.UtcNow.AddDays(-1)); _totalOriginal = await Database.Files.SumAsync(x => (long?)x.OriginalSize) ?? 0; _totalProcessed = await Database.Files.SumAsync(x => (long?)(x.ProcessedSize ?? x.OriginalSize)) ?? 0; _files = await Database.Files.AsNoTracking().Include(x => x.Uploader).OrderByDescending(x => x.CreatedAt).Take(500).ToListAsync(); _users = await Database.Users.AsNoTracking().Include(x => x.Files).OrderByDescending(x => x.CreatedAt).Take(250).ToListAsync(); _reports = await Database.Reports.AsNoTracking().Include(x => x.File).Where(x => x.Status == ReportStatus.Pending).OrderBy(x => x.CreatedAt).Take(100).ToListAsync(); _audit = await Database.AuditLogs.AsNoTracking().Include(x => x.Actor).OrderByDescending(x => x.CreatedAt).Take(250).ToListAsync(); }
    private string TypeStyle(long value) { var max = _files.GroupBy(x => x.Type).Select(x => x.Sum(f => f.OriginalSize)).DefaultIfEmpty(1).Max(); return $"width:{100d * value / Math.Max(1, max):0}%"; }
    private static string FileState(FileUpload file) => file.IsHidden ? "Hidden" : file.IsNsfw ? "NSFW" : file.ProcessingStatus.ToString();
    private static string Format(long value) => FileCard.FormatBytes(value);
}
