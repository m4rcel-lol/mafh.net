@page "/"
@inject AppDbContext Database

<PageTitle>m5rcel's awesome file hoster</PageTitle>
<section class="hero minimal-hero">
    <div class="hero-copy reveal">
        <span class="eyebrow">SELF-HOSTED FILES</span>
        <h1>Files, kept simple.</h1>
        <p>Upload, share and manage files without sending them to someone else's storage.</p>
        <div class="hero-actions">
            <AuthorizeView><Authorized><a class="button filled large" href="/dashboard">Open dashboard</a></Authorized><NotAuthorized><a class="button filled large" href="/register">Create account</a></NotAuthorized></AuthorizeView>
            <a class="button tonal large" href="/uploads">Browse uploads</a>
        </div>
        <div class="trust-row"><span>Local storage</span><span>Private links</span><span>Automatic processing</span></div>
    </div>
</section>

<section class="section-block compact-features">
    <div class="feature-grid">
        <article class="feature-card"><span class="emoji-icon" aria-hidden="true">📁</span><h3>Stored here</h3><p>Your files stay on this server.</p></article>
        <article class="feature-card"><span class="emoji-icon" aria-hidden="true">⚙️</span><h3>Processed for you</h3><p>Media is optimized in the background.</p></article>
        <article class="feature-card"><span class="emoji-icon" aria-hidden="true">🔗</span><h3>Shared your way</h3><p>Choose public, unlisted or private access.</p></article>
    </div>
</section>

<section class="section-block" hidden="@(_recent.Count == 0)">
        <div class="section-heading inline">
            <div><span class="eyebrow">FRESH DROPS</span><h2>Recently uploaded</h2></div>
            <a class="button text" href="/uploads">See everything →</a>
        </div>
        <div class="file-grid">
            @foreach (var file in _recent)
            {
                <FileCard File="file" />
            }
        </div>
</section>

<footer class="footer"><strong>m5rcel's awesome file hoster</strong><span>Files served locally.</span><nav><a href="/terms">Terms</a><a href="/privacy">Privacy</a><a href="/rules">Rules</a><a href="/dmca">DMCA</a></nav></footer>

@code {
    private List<FileUpload> _recent = [];
    protected override async Task OnInitializedAsync() => _recent = await Database.Files.AsNoTracking().Include(x => x.Uploader).Where(x => x.Visibility == FileVisibility.Public && !x.IsHidden && !x.IsNsfw && !x.Uploader.IsBanned).OrderByDescending(x => x.CreatedAt).Take(4).ToListAsync();
}
