@page "/reset-password"
@inject NavigationManager Navigation
<PageTitle>Reset password · m5 file hoster</PageTitle>
<div class="auth-page"><section class="auth-card"><span class="state-icon">🔑</span><h1>Choose a new password</h1><p class="subtle">Reset links are single-use and expire according to the Identity token policy.</p><form method="post" action="/api/auth/reset-password" class="form-stack"><AntiforgeryToken /><input type="hidden" name="userId" value="@UserId" /><input type="hidden" name="token" value="@Token" /><label><span>New password</span><input type="password" name="password" required minlength="12" maxlength="128" autocomplete="new-password" /></label><button class="button filled full">Reset password</button></form></section></div>
@code {
    private string? UserId => Query("userId"); private string? Token => Query("token");
    private string? Query(string name) { var query = QueryHelpers.ParseQuery(new Uri(Navigation.Uri).Query); return query.TryGetValue(name, out var value) ? value.ToString() : null; }
}
