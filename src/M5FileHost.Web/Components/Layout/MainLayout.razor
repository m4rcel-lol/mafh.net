@inherits LayoutComponentBase

<div class="app-shell">
    <header class="topbar">
        <a class="brand" href="/"><span class="brand-mark">m5</span><span>m5rcel's awesome file hoster</span></a>
        <nav class="top-actions">
            <AuthorizeView>
                <Authorized><a class="avatar" href="/settings" aria-label="Account">@context.User.Identity?.Name?.Substring(0, 1).ToUpperInvariant()</a></Authorized>
                <NotAuthorized><a class="button tonal compact" href="/login">Sign in</a></NotAuthorized>
            </AuthorizeView>
        </nav>
    </header>
    <aside class="nav-rail" aria-label="Primary navigation">
        <NavLink href="/" Match="NavLinkMatch.All"><span class="emoji-icon" aria-hidden="true">🏠</span><small>Home</small></NavLink>
        <NavLink href="/uploads"><span class="emoji-icon" aria-hidden="true">🗂️</span><small>Browse</small></NavLink>
        <AuthorizeView><Authorized>
            <NavLink href="/upload" class="rail-fab"><span class="emoji-icon" aria-hidden="true">📤</span><small>Upload</small></NavLink>
            <NavLink href="/dashboard"><span class="emoji-icon" aria-hidden="true">📊</span><small>Dashboard</small></NavLink>
            <AuthorizeView Policy="Moderator"><Authorized Context="adminState"><NavLink href="/admin"><span class="emoji-icon" aria-hidden="true">🛠️</span><small>Admin</small></NavLink></Authorized></AuthorizeView>
        </Authorized></AuthorizeView>
    </aside>
    <main class="content">@Body</main>
    <nav class="bottom-nav" aria-label="Mobile navigation">
        <NavLink href="/" Match="NavLinkMatch.All"><span class="emoji-icon" aria-hidden="true">🏠</span><small>Home</small></NavLink>
        <NavLink href="/uploads"><span class="emoji-icon" aria-hidden="true">🗂️</span><small>Browse</small></NavLink>
        <AuthorizeView><Authorized><NavLink href="/upload"><span class="emoji-icon" aria-hidden="true">📤</span><small>Upload</small></NavLink><NavLink href="/dashboard"><span class="emoji-icon" aria-hidden="true">📊</span><small>You</small></NavLink></Authorized></AuthorizeView>
    </nav>
</div>
